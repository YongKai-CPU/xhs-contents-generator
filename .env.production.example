# ============================================================
# Xiaohongshu Content Generator - Production Environment Template
# ============================================================
# Copy this file to .env.production and fill in your values
# NEVER commit .env.production to version control!
# ============================================================

# ============================================================
# Server Configuration
# ============================================================
PORT=3000
NODE_ENV=production

# ============================================================
# AI API Configuration (DashScope / Qwen)
# ============================================================
# Get your API key from: https://dashscope.console.aliyun.com/
AI_API_KEY=sk-your_api_key_here

# AI API Base URL (DashScope compatible mode)
AI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# AI Model (Qwen)
AI_MODEL=qwen-turbo

# DashScope API Key for Speech-to-Text (same as AI_API_KEY if using same account)
DASHSCOPE_API_KEY=sk-your_api_key_here

# ============================================================
# Supabase Database Configuration
# ============================================================
# Get these from Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# ============================================================
# Cloudflare R2 Storage Configuration
# ============================================================
# Get these from Cloudflare Dashboard > R2
R2_ACCOUNT_ID=your_account_id_here
R2_BUCKET_NAME=xhs-artifacts
R2_ACCESS_KEY_ID=your_access_key_here
R2_SECRET_ACCESS_KEY=your_secret_key_here

# Optional: Public URL for R2 bucket (if public access enabled)
# R2_PUBLIC_URL=https://pub-your_account_id.r2.cloudflarestorage.com

# ============================================================
# Firebase Authentication
# ============================================================
# Option 1: Use service account JSON file (RECOMMENDED)
# Upload serviceAccountKey.json to Railway
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option 2: Use individual environment variables (alternative)
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ============================================================
# Session Configuration
# ============================================================
# Session cookie name
SESSION_COOKIE_NAME=__session

# Session expiration in days
SESSION_EXPIRES_DAYS=5

# Cookie secure flag (MUST be true in production with HTTPS)
COOKIE_SECURE=true

# Cookie domain (optional, for custom domains)
# COOKIE_DOMAIN=.yourdomain.com

# ============================================================
# CSRF Configuration
# ============================================================
CSRF_COOKIE_NAME=csrf_token

# ============================================================
# Railway Backend Configuration
# ============================================================
# Your Railway app URL (for Cloudflare Worker to connect to)
RAILWAY_BACKEND_URL=https://your-app.railway.app

# ============================================================
# Cloudflare Worker Configuration
# ============================================================
# Your Cloudflare Worker URL (for frontend to connect to)
CLOUDFLARE_WORKER_URL=https://xhs-generator-worker.your-subdomain.workers.dev

# Rate limiting configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ============================================================
# Telegram Bot Configuration
# ============================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your public URL for webhook (for production)
TELEGRAM_WEBHOOK_URL=https://api.yourdomain.com/telegram/webhook

# Telegram bot username
TELEGRAM_BOT_USERNAME=xhs54321_bot

# ============================================================
# CORS Configuration
# ============================================================
# Allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com

# ============================================================
# File Paths (Auto-configured, don't change unless needed)
# ============================================================
# FFmpeg path (if custom location needed)
# FFMPEG_PATH=/usr/bin/ffmpeg

# yt-dlp path (if custom location needed)
# YT_DLP_PATH=/usr/bin/yt-dlp

# ============================================================
# Logging Configuration
# ============================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================
# Optional: Analytics & Monitoring
# ============================================================
# Sentry DSN (for error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# Google Analytics
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# Optional: Email Configuration (for future features)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-password

# ============================================================
# Optional: Premium Features (for future monetization)
# ============================================================
# Stripe API Key
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# ============================================================
# Deployment Checklist
# ============================================================
# Before deploying to production, ensure:
# [ ] All API keys are set
# [ ] Supabase schema is applied (run db/supabase-schema.sql)
# [ ] R2 bucket is created and accessible
# [ ] Firebase service account JSON is uploaded to Railway
# [ ] COOKIE_SECURE=true for HTTPS
# [ ] CORS_ALLOWED_ORIGINS is set to your domain
# [ ] Telegram webhook URL is updated
# [ ] Railway backend URL is set in Cloudflare Worker
# [ ] All secrets are set via wrangler secret for Cloudflare
# ============================================================
