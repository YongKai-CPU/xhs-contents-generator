# Xiaohongshu Content Generator - Environment Variables

# ============================================================
# Server Configuration
# ============================================================
# Server Port (default: 3000)
PORT=3000

# Environment (development | production)
NODE_ENV=development

# ============================================================
# AI API Configuration (DashScope / Qwen)
# ============================================================
# Get your API key from: https://dashscope.console.aliyun.com/
AI_API_KEY=your_api_key_here

# AI API Base URL (DashScope compatible mode)
AI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# AI Model (Qwen)
AI_MODEL=qwen-turbo

# DashScope API Key for Speech-to-Text (same as AI_API_KEY if using same account)
DASHSCOPE_API_KEY=your_api_key_here

# ============================================================
# Firebase Authentication (Google + Facebook Login)
# ============================================================
# Get these from Firebase Console > Project Settings > Service Accounts
# Option 1: Use service account JSON file (RECOMMENDED)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Option 2: Use individual environment variables
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"

# ============================================================
# Session Configuration
# ============================================================
# Session cookie name (Cloudflare compatible)
SESSION_COOKIE_NAME=__session

# Session expiration in days
SESSION_EXPIRES_DAYS=5

# Cookie secure flag (true in production with HTTPS)
COOKIE_SECURE=false

# ============================================================
# CSRF Configuration
# ============================================================
CSRF_COOKIE_NAME=csrf_token

# ============================================================
# WHAPI Configuration (WhatsApp/Telegram - Optional)
# ============================================================
# WHAPI API base URL
WHAPI_BASE_URL=https://api.whapi.com

# WHAPI API token
WHAPI_TOKEN=your_whapi_token_here

# Webhook verification token
WHAPI_VERIFY_TOKEN=your_verify_token_here

# ============================================================
# Telegram Bot Configuration (Direct API - Recommended)
# ============================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your public URL for webhook (for production)
# For local testing with ngrok: https://your-ngrok-url.ngrok.io/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# ============================================================
# File Paths (Auto-configured, don't change unless needed)
# ============================================================
# FFmpeg path (Windows)
# FFMPEG_PATH=C:\path\to\ffmpeg\bin

# yt-dlp path
# YT_DLP_PATH=C:\path\to\yt-dlp.exe
